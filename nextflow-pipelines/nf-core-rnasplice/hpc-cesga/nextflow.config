// ============================================================
// CESGA PROFILE — optimized for nf-core pipelines on SLURM
// ============================================================

profiles {
  cesga {
    workDir = '/mnt/lustre/scratch/nlsas/home/otras/cim/smv/work-rnasplice-86samples'

    // ---------------------------
    // GLOBAL EXECUTOR SETTINGS
    // ---------------------------
    executor {
      name = 'slurm'
      queueSize = 30
      submitRateLimit = '30/2min'
    }

    // ---------------------------
    // Container runtime settings
    // ---------------------------
    singularity {
      enabled = true
      autoMounts = true
      cacheDir = '/mnt/lustre/scratch/nlsas/home/otras/cim/smv/singularity_images'
      runOptions = '-B /mnt/lustre/scratch/nlsas/home/otras/cim/smv'
    }

    // ---------------------------
    // Process execution defaults
    // ---------------------------
    process {
      // executor = 'slurm'
      scratch = true
   
      // ---------------------------
      // Default resources
      // ---------------------------
      cpus = 4
      memory = { 8.GB * task.attempt }
      time = '4h'
      maxForks = 10

      resourceLimits = [
        memory: 128.GB,
        cpus: 32,
        time: 72.h
      ]

      // ---------------------------
      // Retry strategy
      // ---------------------------
      maxRetries = 1
      maxErrors = 3
      retryInterval = '2min'

      errorStrategy = {
        task.exitStatus in [137, 143] ? 'retry' : 'terminate'
      }

      // =====================================================
      // HEAVY JOBS
      // =====================================================

      withName: 'NFCORE_RNASPLICE:RNASPLICE:PREPARE_GENOME:STAR_GENOMEGENERATE' {
        queue = 'medium'
        cpus = 10
        memory = { 64.GB * task.attempt }
        time = '10h'
      }

      withName: 'NFCORE_RNASPLICE:RNASPLICE:SALMON_QUANT_SALMON' {
        queue = 'medium'
        maxForks = 10  
        cpus = 8
        memory = { 64.GB * task.attempt }
        time = '10h'
      }

      withName: 'NFCORE_RNASPLICE:RNASPLICE:SALMON_QUANT_STAR' {
        scratch = true
        queue = 'medium'
        maxForks = 10  
        cpus = 8
        memory = { 64.GB * task.attempt }
        time = '10h'
      }

      withName: 'NFCORE_RNASPLICE:RNASPLICE:ALIGN_STAR:STAR_ALIGN' {
        scratch = true
        queue = 'medium'
        maxForks = 5  
        cpus = 8
        memory = { 64.GB * task.attempt }
        time = '10h'
      }

      withName: 'NFCORE_RNASPLICE:RNASPLICE:VISUALISE_MISO:MISO_RUN' {
        //queue = 'short'
        //maxForks = 20  
        scratch = true
        cpus = 8
        memory = { 64.GB * task.attempt }
        time = '10h'
      }

      withName: 'NFCORE_RNASPLICE:RNASPLICE:PREPARE_GENOME:SALMON_INDEX' {
        queue = 'medium'
        cpus = 10
        memory = { 32.GB * task.attempt }
        time = '10h'
      }

      withName: 'NFCORE_RNASPLICE:RNASPLICE:ALIGN_STAR:BAM_SORT_STATS_SAMTOOLS:SAMTOOLS_SORT' {
        //queue = 'short'
        scratch = true
        maxForks = 10  
        cpus = 8
        memory = { 32.GB * task.attempt }
        time = '8h'
        // clusterOptions = '--mem=110G'
      }

      // =====================================================
      // MEDIUM JOBS
      // =====================================================

      withName: 'NFCORE_RNASPLICE:RNASPLICE:DEXSEQ_DEU:DEXSEQ_EXON' {
        cpus = 4
        memory = { 16.GB * task.attempt }
        time = '12h'
      }

      withName: 'NFCORE_RNASPLICE:RNASPLICE:FASTQ_FASTQC_UMITOOLS_TRIMGALORE:TRIMGALORE' {
        queue = 'short'
        maxForks = 10  
        cpus = 8
        memory = { 8.GB * task.attempt }
        time = '4h'
      }

      // =====================================================
      // LIGHT JOBS
      // =====================================================      

      withName: 'NFCORE_RNASPLICE:RNASPLICE:DEXSEQ_DEU:DEXSEQ_COUNT' {
        scratch = true
        queue = 'short'
        maxForks = 5  
        cpus = 8
        memory = { 16.GB * task.attempt }
        time = '12h'
      }

      withName: 'NFCORE_RNASPLICE:RNASPLICE:RMATS:RMATS_POST' {
        scratch = true
        cpus = 4
        memory = { 8.GB * task.attempt }
        time = '12h'
      }
      
      // =====================================================
      // NOT IN TEST PROFILE 
      // =====================================================
      /*
      withName: 'DIFFSPLICE_IOE' {
        memory = 55.GB
        cpus = 10
        time = 12.h
      }

      withName: 'STAR_ALIGN_IGENOMES' {
        memory = '55 GB'
        cpus = 10
        time = 6.h
      }

      withName: 'GPROFILER2_GOST' {
        executor = "local"
        memory = 30.GB
        cpus = 3
        time = 5.h
      }

      withName: 'GSEA_GSEA' {
        memory = 110.GB
        cpus = 20
        time = 24.h
        containerOptions = '-e'
        beforeScript = """
        export JAVA_TOOL_OPTIONS='-Xmx100g -Duser.home=$PWD'
        mkdir -p "$PWD/gsea_home"
        """
      }

      withName: 'RSEQC_READDUPLICATION' {
        memory = 80.GB
        cpus = 10
        time = 5.h
      }

      withName: 'BEDTOOLS_GENOMECOV' {
        memory = 40.GB
        cpus = 10
        time = 6.h
      }

      withName: 'RSEQC_TIN' {
        memory = 40.GB
        cpus = 10
        time = 15.h
      }

      withName: 'QUALIMAP_RNASEQ' {
        memory = 25.GB
        cpus = 6
        time = 5.h
      }

      withName: 'MULTIQC' {
        memory = 25.GB
        cpus = 6
        time = 10.h
      }

      withName: 'GTF_2_GFF3' {
        //queue = 'short'
        //maxForks = 20  
        cpus = 4
        memory = { 16.GB * task.attempt }
        time = '4h'
      }
      */
    }
  }
}